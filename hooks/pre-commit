#!/usr/bin/env sh
set -eu

fw_root="$(git rev-parse --show-toplevel)"
host_root="$(cd "$fw_root/.." && pwd)"
template_root="$fw_root/templates/fw_new/default"

sync_file() {
    src="$1"
    dst="$2"
    rel="${dst#$fw_root/}"

    [ -f "$src" ] || return 0
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    git -C "$fw_root" add "$rel"
}

sync_file "$host_root/.codex/skills/fw/SKILL.md" \
    "$template_root/.codex/skills/fw/SKILL.md.tpl"

if [ -d "$host_root/docs/fw" ]; then
    sync_file "$host_root/docs/fw/rule.md" "$fw_root/docs/rule.md"
    sync_file "$host_root/docs/fw/rule.md" "$template_root/docs/fw/rule.md.tpl"

    # spec/use describe the current host structure and commands. Keep fw/docs in
    # sync, but do not overwrite the default template's own spec/use.
    sync_file "$host_root/docs/fw/spec.md" "$fw_root/docs/spec.md"
    sync_file "$host_root/docs/fw/use.md" "$fw_root/docs/use.md"
else
    sync_file "$fw_root/docs/rule.md" "$template_root/docs/fw/rule.md.tpl"
fi
