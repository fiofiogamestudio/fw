#!/usr/bin/env sh
set -eu

fw_root="$(git rev-parse --show-toplevel)"
template_root="$fw_root/templates/fw_new/default"
changed=0

sync_file() {
    src="$1"
    dst="$2"

    [ -f "$src" ] || {
        echo "fw pre-commit: missing canonical file: ${src#$fw_root/}" >&2
        exit 1
    }
    if [ -f "$dst" ] && cmp -s "$src" "$dst"; then
        return 0
    fi

    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "fw pre-commit: updated ${dst#$fw_root/}" >&2
    changed=1
}

sync_file "$fw_root/.codex/skills/fw/SKILL.md" \
    "$template_root/.codex/skills/fw/SKILL.md.tpl"
sync_file "$fw_root/docs/rule.md" "$template_root/docs/fw/rule.md.tpl"
sync_file "$fw_root/docs/spec.md" "$template_root/docs/fw/spec.md.tpl"
sync_file "$fw_root/docs/use.md" "$template_root/docs/fw/use.md.tpl"

if [ "$changed" -ne 0 ]; then
    echo "fw pre-commit: derived template files changed; review and stage them, then commit again." >&2
    exit 1
fi
